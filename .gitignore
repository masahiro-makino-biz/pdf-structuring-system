# =============================================================================
# .gitignore - Gitで管理しないファイルを指定
# =============================================================================
# 【このファイルの役割】
# ここに書いたファイル/フォルダはGitにアップロードされない
# 秘密情報や自動生成ファイルを除外するために使う
# =============================================================================

# ---------------------------------------------------------------------------
# 環境変数・秘密情報（絶対にアップしてはいけない）
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
credentials.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# データボリューム（ローカルのみ）
data/

# ---------------------------------------------------------------------------
# IDE・エディタ
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# 調査メモ
# ---------------------------------------------------------------------------
wxo-iframe-investigation.txt

# ---------------------------------------------------------------------------
# ログ・一時ファイル
# ---------------------------------------------------------------------------
*.log
*.tmp
*.temp

# ---------------------------------------------------------------------------
# テスト・カバレッジ
# ---------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
