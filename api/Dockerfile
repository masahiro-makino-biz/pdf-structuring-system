# =============================================================================
# api/Dockerfile - APIサーバーのコンテナ設定
# =============================================================================
# 【Dockerfileとは】
# コンテナ（隔離された実行環境）をどう作るかの「レシピ」
# 上から順番に実行され、最終的にコンテナイメージが作られる
# =============================================================================

# ---------------------------------------------------------------------------
# ベースイメージの指定
# ---------------------------------------------------------------------------
# 【FROMとは】土台となるイメージを指定
# 【なぜpython:3.11-slimか】
#   - python:3.11 → Python 3.11がインストール済み
#   - slim → 必要最小限のパッケージのみ（軽量で起動が速い）
# 【他の選択肢】
#   - python:3.11 → フル版。サイズが大きい（約900MB vs slimは約150MB）
#   - python:3.11-alpine → さらに軽量だが、一部ライブラリでトラブルが起きやすい
FROM python:3.11-slim

# ---------------------------------------------------------------------------
# 作業ディレクトリの設定
# ---------------------------------------------------------------------------
# 【WORKDIRとは】以降のコマンドを実行するディレクトリ
# コンテナ内に /app フォルダを作り、そこで作業する
WORKDIR /app

# ---------------------------------------------------------------------------
# 依存ライブラリのインストール
# ---------------------------------------------------------------------------
# 【なぜrequirements.txtを先にコピーするか】
# Dockerはレイヤーキャッシュを使う。requirements.txtが変わらなければ
# pip installをスキップできる（ビルドが速くなる）
#
# 【順番の意味】
# 1. requirements.txt だけ先にコピー
# 2. pip install 実行
# 3. 残りのソースコードをコピー
# → ソースコードだけ変えた場合、pip installは再実行されない（キャッシュ活用）

# ---------------------------------------------------------------------------
# システムライブラリのインストール
# ---------------------------------------------------------------------------
# 【poppler-utilsとは】PDF処理に必要なライブラリ
# pdf2imageがPDFを画像に変換する際に使用する
RUN apt-get update && apt-get install -y poppler-utils && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ---------------------------------------------------------------------------
# ソースコードのコピー
# ---------------------------------------------------------------------------
# 【COPY . .とは】ローカルの現在ディレクトリ(.)をコンテナの現在ディレクトリ(.)にコピー
# ただし、docker-compose.ymlでvolumeマウントしているため、開発中は実質使われない
COPY . .

# ---------------------------------------------------------------------------
# ポートの公開
# ---------------------------------------------------------------------------
# 【EXPOSEとは】このコンテナが使うポートを宣言（ドキュメント的な役割）
# 実際のポート公開はdocker-compose.ymlのportsで行う
EXPOSE 8000

# ---------------------------------------------------------------------------
# 起動コマンド
# ---------------------------------------------------------------------------
# 【CMDとは】コンテナ起動時に実行するコマンド
# 【uvicornとは】FastAPIを動かすためのWebサーバー
# 【オプションの意味】
#   - main:app → main.pyの中のappオブジェクトを起動
#   - --host 0.0.0.0 → 外部からのアクセスを許可
#   - --port 8000 → 8000番ポートで起動
#   - --reload → コード変更時に自動再起動（開発用）
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
