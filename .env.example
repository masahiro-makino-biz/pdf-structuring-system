# =============================================================================
# .env.example - 環境変数のサンプル
# =============================================================================
# 【使い方】
# 1. このファイルをコピーして .env という名前で保存
#    cp .env.example .env
# 2. .env ファイルを開いて、実際の値を入力
# 3. docker-compose up で起動すると自動で読み込まれる
# =============================================================================

# OpenAI API Key
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
