# =============================================================================
# .env.example - 環境変数設定のテンプレート
# =============================================================================
# 【使い方】
# 1. このファイルを .env にコピー: cp .env.example .env
# 2. 各項目に実際の値を設定
# =============================================================================

# =============================================================================
# LiteLLMモデル設定
# =============================================================================
# 【LITELLM_MODEL】使用するモデル名
# litellm/config.yaml で定義した model_name を指定
# 例: gpt-4o, gpt-4o-mini, claude-3-sonnet, gemini-pro
LITELLM_MODEL=gpt-4o

# =============================================================================
# OpenAI設定
# =============================================================================
# 【OPENAI_API_KEY】OpenAI APIキー
# https://platform.openai.com/api-keys で取得
# 用途: チャット（LiteLLM経由）、PDF解析（直接呼び出し）
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# Azure OpenAI設定（オプション）
# =============================================================================
# 【使い方】
# 1. litellm/config.yaml の Azure セクションをコメント解除
# 2. 以下の環境変数を設定
# 3. LITELLM_MODEL=azure-gpt-4o に変更
#
# AZURE_API_KEY=your-azure-api-key-here
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview

# =============================================================================
# AWS Bedrock設定（オプション）
# =============================================================================
# 【使い方】
# 1. litellm/config.yaml の Bedrock セクションをコメント解除
# 2. 以下の環境変数を設定
# 3. LITELLM_MODEL=claude-3-sonnet に変更
#
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1

# =============================================================================
# Google Gemini設定（オプション）
# =============================================================================
# 【使い方】
# 1. litellm/config.yaml の Gemini セクションをコメント解除
# 2. 以下の環境変数を設定
# 3. LITELLM_MODEL=gemini-pro に変更
#
# GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# Anthropic直接設定（オプション）
# =============================================================================
# 【使い方】
# 1. litellm/config.yaml の Anthropic セクションをコメント解除
# 2. 以下の環境変数を設定
# 3. LITELLM_MODEL=claude-direct に変更
#
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
